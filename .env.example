# CodeBuddy API Key (required)
# Get your API key from https://www.codebuddy.cn
CODEBUDDY_API_KEY=

# Optional: Auth Token (alternative to API Key)
# CODEBUDDY_AUTH_TOKEN=

# Optional: Internet Environment
# CODEBUDDY_INTERNET_ENVIRONMENT=

# Optional: Custom Base URL
# CODEBUDDY_BASE_URL=

# 自定义模型 API 配置（OpenAI 兼容接口）
CUSTOM_MODEL_API_URL=
CUSTOM_MODEL_API_KEY=
CUSTOM_MODEL_NAME=

# Server Port (default: 3000)
# PORT=3000
